---
---

<div class="cf-wrapper not-content">
  <div class="cf-card">
    <form action="https://api.web3forms.com/submit" method="POST" id="form">
      <input type="hidden" name="access_key" value="31a49089-9b40-4bf6-89a7-fa5a56535661" />
      <input type="hidden" name="subject" value="New Contact Form Submission from Code Search" />
      <input type="hidden" name="from_name" value="Code Search Website" />
      <input type="checkbox" name="botcheck" style="display: none;" />

      <div class="cf-row">
        <div class="cf-field">
          <label for="cf-name">Full Name</label>
          <input type="text" name="name" id="cf-name" placeholder="John Doe" required />
        </div>
        <div class="cf-field">
          <label for="cf-email">Email Address</label>
          <input type="email" name="email" id="cf-email" placeholder="john@example.com" required />
        </div>
      </div>

      <div class="cf-field">
        <label for="cf-message">Message</label>
        <textarea name="message" id="cf-message" rows="5" placeholder="How can we help you?" required></textarea>
      </div>

      <button type="submit" id="cf-submit" class="cf-btn">
        <span class="cf-btn-label">
          Send Message
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
        </span>
        <span class="cf-btn-spinner" style="display:none;">
          <svg class="cf-spin" viewBox="0 0 50 50"><circle cx="25" cy="25" r="20" fill="none" stroke="currentColor" stroke-width="5" stroke-linecap="round"/></svg>
        </span>
        <span class="cf-btn-result" style="display:none;"></span>
      </button>
    </form>
  </div>

  <a href="https://github.com/techquestsdev/code-search/issues" target="_blank" rel="noopener noreferrer" class="cf-github">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
    <div>
      <strong>Prefer GitHub?</strong>
      <span>Open an issue for bugs, feature requests, or technical discussions.</span>
    </div>
    <svg class="cf-github-arrow" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
  </a>
</div>

<style>
  .cf-wrapper {
    margin: 1.5rem 0 2rem;
  }

  /* ---- Card ---- */
  .cf-card {
    background: var(--sl-color-gray-7);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.75rem;
    padding: 1.75rem;
  }

  /* ---- Row: name + email side by side ---- */
  .cf-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  @media (max-width: 540px) {
    .cf-row {
      grid-template-columns: 1fr;
      gap: 0;
    }
    .cf-row .cf-field {
      margin-bottom: 1rem;
    }
  }

  /* ---- Fields inside row: no margin, grid gap handles spacing ---- */
  .cf-row > .cf-field {
    margin-bottom: 0;
  }

  /* ---- Standalone field (e.g. message) ---- */
  .cf-field {
    margin-bottom: 1rem;
  }

  .cf-field:last-child {
    margin-bottom: 0;
  }

  /* ---- Label ---- */
  .cf-card label {
    display: block;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--sl-color-gray-2);
    margin-bottom: 0.375rem;
  }

  /* ---- Inputs ---- */
  .cf-card input[type="text"],
  .cf-card input[type="email"],
  .cf-card textarea {
    display: block;
    width: 100%;
    padding: 0.625rem 0.75rem;
    background: var(--sl-color-bg);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.375rem;
    color: var(--sl-color-white);
    font-family: inherit;
    font-size: 0.875rem;
    line-height: 1.5;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
    box-sizing: border-box;
  }

  .cf-card input::placeholder,
  .cf-card textarea::placeholder {
    color: var(--sl-color-gray-4);
  }

  .cf-card input:focus,
  .cf-card textarea:focus {
    outline: none;
    border-color: var(--sl-color-accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--sl-color-accent) 15%, transparent);
  }

  .cf-card textarea {
    resize: vertical;
    min-height: 110px;
  }

  /* ---- Submit button ---- */
  .cf-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 2.625rem;
    margin-top: 1.25rem;
    background: var(--sl-color-accent);
    color: #fff;
    border: none;
    border-radius: 0.375rem;
    font-family: inherit;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease;
  }

  .cf-btn:hover {
    background: var(--sl-color-accent-high);
    transform: translateY(-1px);
    box-shadow: 0 4px 12px color-mix(in srgb, var(--sl-color-accent) 30%, transparent);
  }

  .cf-btn:active {
    transform: translateY(0);
  }

  .cf-btn:disabled {
    opacity: 0.65;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
  }

  .cf-btn-label {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  /* ---- Spinner ---- */
  .cf-spin {
    width: 20px;
    height: 20px;
    animation: cf-rotate 1s linear infinite;
    stroke-dasharray: 90, 150;
    stroke-dashoffset: -35;
  }

  @keyframes cf-rotate {
    100% { transform: rotate(360deg); }
  }

  .cf-btn-result {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .cf-btn.success {
    background: #10b981;
  }

  .cf-btn.success:hover {
    background: #059669;
  }

  .cf-btn.error {
    background: #ef4444;
  }

  .cf-btn.error:hover {
    background: #dc2626;
  }

  /* ---- GitHub link card ---- */
  .cf-github {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.75rem;
    padding: 0.875rem 1rem;
    background: var(--sl-color-gray-7);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.75rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }

  .cf-github:hover {
    border-color: var(--sl-color-gray-4);
    transform: translateY(-1px);
  }

  .cf-github > svg:first-child {
    flex-shrink: 0;
    color: var(--sl-color-gray-2);
  }

  .cf-github div {
    flex: 1;
    min-width: 0;
  }

  .cf-github strong {
    display: block;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--sl-color-white);
    line-height: 1.3;
  }

  .cf-github span {
    font-size: 0.8125rem;
    color: var(--sl-color-gray-3);
    line-height: 1.3;
  }

  .cf-github-arrow {
    flex-shrink: 0;
    color: var(--sl-color-gray-4);
    transition: transform 0.15s ease;
  }

  .cf-github:hover .cf-github-arrow {
    transform: translateX(2px);
    color: var(--sl-color-gray-3);
  }
</style>

<script is:inline>
  (function() {
    var form = document.getElementById('form');
    var btn = document.getElementById('cf-submit');
    var label = btn.querySelector('.cf-btn-label');
    var spinner = btn.querySelector('.cf-btn-spinner');
    var btnResult = btn.querySelector('.cf-btn-result');

    function showResult(text, type) {
      spinner.style.display = 'none';
      label.style.display = 'none';
      btnResult.textContent = text;
      btnResult.style.display = 'inline-flex';
      btn.classList.add(type);
      btn.disabled = true;

      setTimeout(function() {
        btnResult.style.display = 'none';
        btn.classList.remove(type);
        label.style.display = '';
        btn.disabled = false;
      }, 3000);
    }

    form.addEventListener('submit', function(e) {
      e.preventDefault();
      btn.disabled = true;
      label.style.display = 'none';
      spinner.style.display = 'inline-flex';

      var fd = new FormData(form);
      var obj = {};
      fd.forEach(function(v, k) { obj[k] = v; });

      fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify(obj)
      })
      .then(function(res) { return res.json().then(function(j) { return { ok: res.ok, json: j }; }); })
      .then(function(r) {
        if (r.ok) {
          form.reset();
          showResult('Message sent successfully!', 'success');
        } else {
          showResult(r.json.message || 'Failed to send message.', 'error');
        }
      })
      .catch(function() {
        showResult('Something went wrong. Please try again.', 'error');
      });
    });
  })();
</script>
