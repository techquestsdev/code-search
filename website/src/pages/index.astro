<style>
  /* ============================================
     CSS Custom Properties
     ============================================ */
  :root {
    --lp-font: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      Roboto, "Helvetica Neue", Arial, sans-serif;
    --lp-font-mono: "SF Mono", "Menlo", "Monaco", "Consolas", monospace;
  }

  /* Dark theme (default) */
  :root,
  [data-theme="dark"] {
    --lp-accent: #3b82f6;
    --lp-accent-high: #60a5fa;
    --lp-bg: #030712;
    --lp-bg-alt: #111827;
    --lp-card-bg: #1f2937;
    --lp-card-border: #374151;
    --lp-text: #ffffff;
    --lp-text-secondary: #d1d5db;
    --lp-text-muted: #9ca3af;
    --lp-border: #374151;
    --lp-header-bg: #111827;
    --lp-code-bg: #111827;
    --lp-code-border: #374151;
  }

  /* Light theme */
  [data-theme="light"] {
    --lp-accent: #2563eb;
    --lp-accent-high: #1d4ed8;
    --lp-bg: #ffffff;
    --lp-bg-alt: #f9fafb;
    --lp-card-bg: #f3f4f6;
    --lp-card-border: #d1d5db;
    --lp-text: #111827;
    --lp-text-secondary: #4b5563;
    --lp-text-muted: #6b7280;
    --lp-border: #d1d5db;
    --lp-header-bg: #f9fafb;
    --lp-code-bg: #f6f8fa;
    --lp-code-border: #d1d9e0;
  }

  /* ============================================
     Reset & Base
     ============================================ */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: var(--lp-font);
    background: var(--lp-bg);
    color: var(--lp-text);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img,
  video {
    max-width: 100%;
    height: auto;
    display: block;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .container-wide {
    max-width: 1280px;
  }

  /* ============================================
     Header
     ============================================ */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--lp-header-bg);
    border-bottom: 1px solid var(--lp-border);
    backdrop-filter: blur(12px);
  }

  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 3.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo-link {
    display: flex;
    align-items: center;
  }

  .logo {
    display: none;
  }

  [data-theme="dark"] .logo-dark {
    display: block;
  }

  [data-theme="light"] .logo-light {
    display: block;
  }

  /* If no data-theme yet, default to dark */
  :root:not([data-theme]) .logo-dark {
    display: block;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-links a {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--lp-text-secondary);
    transition: color 0.15s ease;
  }

  .nav-links a:hover {
    color: var(--lp-text);
  }

  .nav-icon-link {
    display: flex;
    align-items: center;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  /* Theme Select Component */
  .theme-select-container {
    display: flex;
    align-items: center;
  }

  .theme-select-label {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    color: var(--lp-text-secondary);
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    border-radius: 0.375rem;
    transition: color 0.15s ease, background-color 0.15s ease;
  }

  .theme-select-label:hover {
    color: var(--lp-text);
    background-color: var(--lp-card-bg);
  }

  .theme-select-label select {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    cursor: pointer;
    appearance: none;
  }

  .icon-label {
    display: none;
    flex-shrink: 0;
  }

  .icon-caret {
    flex-shrink: 0;
    width: 12px;
    height: 12px;
    opacity: 0.5;
  }

  /* Show icon based on actual theme state or select value?
     Starlight shows the icon matching the CURRENT theme.
  */
  [data-theme="dark"] .icon-sun,
  /* Show icon matching the selected theme */
  /* If we want to perfectly match Starlight, we should use JS to toggle these classes based on select value */

  .theme-select-label .icon-label { display: none; }

  /* These will be toggled via JS based on the select value */
  .theme-select-label[data-chosen="light"] .icon-sun { display: block; }
  .theme-select-label[data-chosen="dark"] .icon-moon { display: block; }
  .theme-select-label[data-chosen="auto"] .icon-auto { display: block; }

  /* Fallback if no data-chosen yet */
  .theme-select-label:not([data-chosen]) .icon-auto { display: block; }

  @media (max-width: 640px) {
    .theme-select-label {
      padding: 0.25rem;
    }
    .icon-caret {
      display: none;
    }
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  /* Hamburger */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem;
  }

  .hamburger span {
    display: block;
    width: 18px;
    height: 2px;
    background: var(--lp-text-secondary);
    border-radius: 1px;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .hamburger[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  .hamburger[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
  }
  .hamburger[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  /* Mobile menu */
  .mobile-menu {
    display: none;
    flex-direction: column;
    background: var(--lp-header-bg);
    border-bottom: 1px solid var(--lp-border);
    padding: 0.75rem 1.5rem 1rem;
  }

  .mobile-menu.open {
    display: flex;
  }

  .mobile-menu a {
    padding: 0.625rem 0;
    font-size: 0.9375rem;
    color: var(--lp-text-secondary);
    border-bottom: 1px solid var(--lp-border);
  }

  .mobile-menu a:last-child {
    border-bottom: none;
  }

  .mobile-menu a:hover {
    color: var(--lp-text);
  }

  @media (max-width: 640px) {
    .nav-links {
      display: none;
    }

    .hamburger {
      display: flex;
    }
  }

  /* ============================================
     Hero
     ============================================ */
  .hero {
    text-align: center;
    padding: 5rem 1rem 3rem;
    background: radial-gradient(
      ellipse 80% 60% at 50% 40%,
      rgba(59, 130, 246, 0.08) 0%,
      transparent 70%
    );
  }

  [data-theme="light"] .hero {
    background: radial-gradient(
      ellipse 80% 60% at 50% 40%,
      rgba(37, 99, 235, 0.06) 0%,
      transparent 70%
    );
  }

  .hero h1 {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.15;
    margin-bottom: 1.25rem;
  }

  .hero-icon {
    width: 2.5rem;
    height: 2.5rem;
    flex-shrink: 0;
    color: var(--lp-accent);
  }

  .tagline {
    font-size: 1.2rem;
    line-height: 1.6;
    color: var(--lp-text-secondary);
    max-width: 700px;
    margin: 0 auto 2rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (min-width: 50rem) {
    .hero h1 {
      font-size: 3.5rem;
    }

    .hero-icon {
      width: 5.5rem;
      height: 5.5rem;
    }
  }

  /* ============================================
     Buttons
     ============================================ */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1.25rem;
    border-radius: 0.5rem;
    font-weight: 500;
    font-size: 0.875rem;
    transition: all 0.15s ease;
    border: none;
    cursor: pointer;
  }

  .btn-primary {
    background: var(--lp-accent);
    color: #fff;
  }

  .btn-primary:hover {
    background: var(--lp-accent-high);
    box-shadow: 0 4px 14px rgba(59, 130, 246, 0.4);
    transform: translateY(-1px);
  }

  [data-theme="light"] .btn-primary:hover {
    box-shadow: 0 4px 14px rgba(37, 99, 235, 0.3);
  }

  .btn-secondary {
    background: var(--lp-card-bg);
    color: var(--lp-text);
    border: 1px solid var(--lp-card-border);
  }

  .btn-secondary:hover {
    background: var(--lp-border);
  }

  /* ============================================
     Demo Video
     ============================================ */
  .demo-section {
    padding: 0 1rem 3rem;
  }

  .demo-video-wrap {
    margin: 0 auto;
    border-radius: 0.75rem;
    overflow: hidden;
    box-shadow: 0 25px 60px -12px rgba(0, 0, 0, 0.5),
      0 0 40px -15px rgba(59, 130, 246, 0.15);
    border: 1px solid var(--lp-card-border);
