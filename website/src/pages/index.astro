---
// Custom landing page — shadows Starlight's generated index
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Code Search - Self-hosted code search across repositories</title>
    <meta
      name="description"
      content="Self-hosted code search and bulk operations across all your repositories. Search, find, and replace code at scale with CLI and web UI."
    />
    <meta
      name="keywords"
      content="code search, self-hosted, source code, repository search, bulk replace, CLI, code indexing, developer tools, DevOps"
    />
    <meta name="author" content="Code Search" />
    <meta name="robots" content="index, follow" />

    <!-- OpenGraph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://code-search.techquests.dev/" />
    <meta
      property="og:title"
      content="Code Search - Self-hosted code search across repositories"
    />
    <meta
      property="og:description"
      content="Self-hosted code search and bulk operations across all your repositories. Search, find, and replace code at scale."
    />
    <meta
      property="og:image"
      content="https://code-search.techquests.dev/og-image.png"
    />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Code Search" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content="https://code-search.techquests.dev/" />
    <meta
      name="twitter:title"
      content="Code Search - Self-hosted code search across repositories"
    />
    <meta
      name="twitter:description"
      content="Self-hosted code search and bulk operations across all your repositories. Search, find, and replace code at scale."
    />
    <meta
      name="twitter:image"
      content="https://code-search.techquests.dev/og-image.png"
    />

    <meta name="theme-color" content="#1e293b" />
    <link rel="canonical" href="https://code-search.techquests.dev/" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.svg" />

    <!-- JSON-LD -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "Code Search",
        "description": "Self-hosted code search and bulk operations across all your repositories",
        "url": "https://code-search.techquests.dev",
        "applicationCategory": "DeveloperApplication",
        "operatingSystem": "Linux, macOS, Windows",
        "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
        "author": { "@type": "Organization", "name": "Code Search" }
      }
    </script>

    <!-- Theme init — prevent FOUC -->
    <script is:inline>
      (function () {
        const theme = localStorage.getItem("starlight-theme") || "auto";
        const isDark =
          theme === "dark" ||
          (theme === "auto" &&
            window.matchMedia("(prefers-color-scheme: dark)").matches);
        document.documentElement.setAttribute("data-theme", isDark ? "dark" : "light");
      })();
    </script>
  </head>

  <body>
    <!-- ===== Header ===== -->
    <header class="site-header">
      <div class="header-inner">
        <a href="/" class="logo-link" aria-label="Code Search home">
          <!-- Dark logo -->
          <svg
            class="logo logo-dark"
            xmlns="http://www.w3.org/2000/svg"
            width="140"
            height="28"
            viewBox="0 0 160 32"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="m12 10-5 6 5 6"
              stroke="#3b82f6"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
            <path
              d="m20 10 5 6-5 6"
              stroke="#3b82f6"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
            <path
              d="m18 8-4 16"
              stroke="#3b82f6"
              stroke-width="2.5"
              stroke-linecap="round"></path>
            <text
              x="38"
              y="22"
              font-family="system-ui, -apple-system, sans-serif"
              font-size="16"
              font-weight="600"
              fill="#f9fafb">Code Search</text
            >
          </svg>
          <!-- Light logo -->
          <svg
            class="logo logo-light"
            xmlns="http://www.w3.org/2000/svg"
            width="140"
            height="28"
            viewBox="0 0 160 32"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="m12 10-5 6 5 6"
              stroke="#2563eb"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
            <path
              d="m20 10 5 6-5 6"
              stroke="#2563eb"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
            <path
              d="m18 8-4 16"
              stroke="#2563eb"
              stroke-width="2.5"
              stroke-linecap="round"></path>
            <text
              x="38"
              y="22"
              font-family="system-ui, -apple-system, sans-serif"
              font-size="16"
              font-weight="600"
              fill="#111827">Code Search</text
            >
          </svg>
        </a>

        <nav class="nav-links" id="nav-links">
          <a href="/getting-started/introduction/">Docs</a>
          <a href="/pricing/">Pricing</a>
          <a href="/contact/">Contact</a>
          <a
            href="https://github.com/techquestsdev/code-search"
            class="nav-icon-link"
            aria-label="GitHub"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg
              viewBox="0 0 16 16"
              width="20"
              height="20"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"
              ></path>
            </svg>
          </a>
        </nav>

        <div class="header-actions">
          <div class="theme-select-container">
            <label class="theme-select-label">
              <span class="sr-only">Select theme</span>
              <!-- Sun icon -->
              <svg
                class="icon-label icon-sun"
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <circle cx="12" cy="12" r="5"></circle>
                <line x1="12" y1="1" x2="12" y2="3"></line>
                <line x1="12" y1="21" x2="12" y2="23"></line>
                <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
                <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
                <line x1="1" y1="12" x2="3" y2="12"></line>
                <line x1="21" y1="12" x2="23" y2="12"></line>
                <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
                <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
              </svg>
              <!-- Moon icon -->
              <svg
                class="icon-label icon-moon"
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
              </svg>
              <!-- Monitor icon (Auto) — matches Starlight docs -->
              <svg
                class="icon-label icon-auto"
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <path d="M21 14h-1V7a3 3 0 0 0-3-3H7a3 3 0 0 0-3 3v7H3a1 1 0 0 0-1 1v2a3 3 0 0 0 3 3h14a3 3 0 0 0 3-3v-2a1 1 0 0 0-1-1ZM6 7a1 1 0 0 1 1-1h10a1 1 0 0 1 1 1v7H6V7Zm14 10a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1v-1h16v1Z"></path>
              </svg>

              <select id="theme-select">
                <option value="dark">Dark</option>
                <option value="light">Light</option>
                <option value="auto" selected>Auto</option>
              </select>

              <svg
                class="icon-caret"
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </label>
          </div>

          <button
            class="hamburger"
            id="hamburger"
            aria-label="Toggle menu"
            aria-expanded="false"
          >
            <span></span>
            <span></span>
            <span></span>
          </button>
        </div>
      </div>
    </header>

    <!-- ===== Mobile menu ===== -->
    <div class="mobile-menu" id="mobile-menu">
      <a href="/getting-started/introduction/">Docs</a>
      <a href="/pricing/">Pricing</a>
      <a href="/contact/">Contact</a>
      <a
        href="https://github.com/techquestsdev/code-search"
        target="_blank"
        rel="noopener noreferrer">GitHub</a
      >
    </div>

    <main>
      <!-- ===== Hero ===== -->
      <section class="hero">
        <div class="container">
          <h1>
            <svg
              class="hero-icon"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 32 32"
              fill="none"
              aria-hidden="true"
            >
              <path
                d="m12 10-5 6 5 6"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
              <path
                d="m20 10 5 6-5 6"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
              <path
                d="m18 8-4 16"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"></path>
            </svg>
             Code Search
          </h1>
          <p class="tagline">
            Search, find, and replace code across all your repositories in
            milliseconds. Self-hosted and built for teams.
          </p>
          <div class="hero-actions">
            <a href="/getting-started/introduction/" class="btn btn-primary"
              >Get Started
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
                  points="12 5 19 12 12 19"></polyline></svg
              >
            </a>
            <a
              href="https://github.com/techquestsdev/code-search"
              class="btn btn-secondary"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg
                viewBox="0 0 16 16"
                width="16"
                height="16"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"
                ></path>
              </svg>
               View on GitHub
            </a>
          </div>
        </div>
      </section>

      <!-- ===== Demo Video ===== -->
      <section class="demo-section">
        <div class="container">
          <div class="demo-video-wrap">
            <video autoplay loop muted playsinline poster="/demo-poster.png">
              <source src="/demo.mp4" type="video/mp4" />
              Your browser does not support the video tag.
            </video>
          </div>
        </div>
      </section>

      <!-- ===== Why Code Search? ===== -->
      <section class="section fade-in-section">
        <div class="container">
          <h2>Why Code Search?</h2>
          <div class="card-grid cols-3">
            <div class="card">
              <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg></div>
              <h3>Lightning Fast</h3>
              <p>
                Powered by Zoekt, the same search engine Google uses internally.
                Search millions of lines of code in milliseconds.
              </p>
            </div>
            <div class="card">
              <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg></div>
              <h3>Bulk Operations</h3>
              <p>
                Find and replace across hundreds of repositories at once.
                Automatically create merge requests with your changes.
              </p>
            </div>
            <div class="card">
              <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg></div>
              <h3>Code Intelligence</h3>
              <p>
                SCIP-powered go-to-definition, find-references, and symbol
                search. Navigate code like an IDE across all your repos.
              </p>
            </div>
            <div class="card">
              <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/></svg></div>
              <h3>AI-Ready</h3>
              <p>
                Built-in MCP server lets AI assistants like Claude and Cursor
                search your code, browse files, and navigate symbols.
              </p>
            </div>
            <div class="card">
              <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></div>
              <h3>Privacy First</h3>
              <p>
                Self-hosted on your infrastructure. Your code never leaves your
                servers. Full control over your data.
              </p>
            </div>
            <div class="card">
              <div class="card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="8" height="8" rx="1"/><rect x="14" y="2" width="8" height="8" rx="1"/><rect x="2" y="14" width="8" height="8" rx="1"/><rect x="14" y="14" width="8" height="8" rx="1"/></svg></div>
              <h3>Scales Horizontally</h3>
              <p>
                Run multiple indexers and API servers. Consistent-hash sharding,
                federated file access, and automatic leader election.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- ===== Quick Start ===== -->
      <section class="section section-alt fade-in-section">
        <div class="container">
          <h2>Quick Start</h2>
          <p class="section-subtitle">
            Get up and running with Docker in a few commands.
          </p>
          <div class="code-block">
            <div class="code-header">
              <span class="code-dot red"></span>
              <span class="code-dot yellow"></span>
              <span class="code-dot green"></span>
            </div>
            <pre><code><span class="code-comment"># Download and start all services</span>
<span class="code-prompt">$</span> curl -O https://raw.githubusercontent.com/techquestsdev/code-search/main/docker-compose.yml
<span class="code-prompt">$</span> docker compose up -d

<span class="code-comment"># Open the web UI</span>
<span class="code-prompt">$</span> open http://localhost:3000</code></pre>
          </div>
        </div>
      </section>

      <!-- ===== Connect All Your Code ===== -->
      <section class="section fade-in-section">
        <div class="container">
          <h2>Connect All Your Code</h2>
          <div class="card-grid cols-2">
            <div class="card">
              <div class="card-icon">
                <svg
                  viewBox="0 0 16 16"
                  width="24"
                  height="24"
                  fill="currentColor"
                >
                  <path
                    d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"
                  ></path>
                </svg>
              </div>
              <h3>GitHub</h3>
              <p>
                GitHub.com and GitHub Enterprise Server. Public and private
                repositories.
              </p>
            </div>
            <div class="card">
              <div class="card-icon">
                <svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor">
                  <path
                    d="M22.65 14.39L12 22.13 1.35 14.39a.84.84 0 0 1-.3-.94l1.22-3.78 2.44-7.51A.42.42 0 0 1 4.82 2a.43.43 0 0 1 .58 0 .42.42 0 0 1 .11.18l2.44 7.49h8.1l2.44-7.51A.42.42 0 0 1 18.6 2a.43.43 0 0 1 .58 0 .42.42 0 0 1 .11.18l2.44 7.51L23 13.45a.84.84 0 0 1-.35.94z"
                  ></path>
