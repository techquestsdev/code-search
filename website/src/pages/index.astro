  /* ============================================
     Scroll Fade-In Animations
     ============================================ */
  .fade-in-section {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }

  .fade-in-section.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Stagger cards */
  .fade-in-section .card-grid > *,
  .fade-in-section .pricing-grid > * {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.4s ease-out, transform 0.4s ease-out;
  }

  .fade-in-section.is-visible .card-grid > *,
  .fade-in-section.is-visible .pricing-grid > * {
    opacity: 1;
    transform: translateY(0);
  }

  .fade-in-section.is-visible .card-grid > *:nth-child(1),
  .fade-in-section.is-visible .pricing-grid > *:nth-child(1) {
    transition-delay: 0s;
  }
  .fade-in-section.is-visible .card-grid > *:nth-child(2),
  .fade-in-section.is-visible .pricing-grid > *:nth-child(2) {
    transition-delay: 0.05s;
  }
  .fade-in-section.is-visible .card-grid > *:nth-child(3),
  .fade-in-section.is-visible .pricing-grid > *:nth-child(3) {
    transition-delay: 0.1s;
  }
  .fade-in-section.is-visible .card-grid > *:nth-child(4),
  .fade-in-section.is-visible .pricing-grid > *:nth-child(4) {
    transition-delay: 0.15s;
  }
  .fade-in-section.is-visible .card-grid > *:nth-child(5) {
    transition-delay: 0.2s;
  }
  .fade-in-section.is-visible .card-grid > *:nth-child(6) {
    transition-delay: 0.25s;
  }

  @media (prefers-reduced-motion: reduce) {
    .fade-in-section {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .fade-in-section .card-grid > *,
    .fade-in-section .pricing-grid > * {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  // Theme toggle
  const themeSelect = document.getElementById("theme-select");
  const themeLabel = themeSelect?.parentElement;

  function setTheme(theme) {
    const isDark =
      theme === "dark" ||
      (theme === "auto" &&
        window.matchMedia("(prefers-color-scheme: dark)").matches);
    document.documentElement.setAttribute("data-theme", isDark ? "dark" : "light");
    if (themeLabel) themeLabel.setAttribute("data-chosen", theme);
    localStorage.setItem("starlight-theme", theme);
    if (themeSelect) themeSelect.value = theme;
  }

  if (themeSelect) {
    const initialTheme = localStorage.getItem("starlight-theme") || "auto";
    setTheme(initialTheme);
    themeSelect.addEventListener("change", (e) => {
      setTheme(e.target.value);
    });
  }

  // Listen for system changes if 'auto' is selected
  window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", () => {
    const theme = localStorage.getItem("starlight-theme") || "auto";
    if (theme === "auto") {
      setTheme("auto");
    }
  });

  // Mobile hamburger
  const hamburger = document.getElementById("hamburger");
  const mobileMenu = document.getElementById("mobile-menu");
  if (hamburger && mobileMenu) {
    hamburger.addEventListener("click", () => {
      const expanded = hamburger.getAttribute("aria-expanded") === "true";
      hamburger.setAttribute("aria-expanded", String(!expanded));
      mobileMenu.classList.toggle("open");
    });
  }

  // Scroll fade-in
  const sections = document.querySelectorAll(".fade-in-section");
  if (sections.length) {
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      sections.forEach((s) => s.classList.add("is-visible"));
    } else {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1 },
      );
      sections.forEach((s) => observer.observe(s));
    }
  }
</script>
